{
  "version": 2,
  "builds": [
    {
      "src": "index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "index.js"
    }
  ],
  "env": {
    "SUBTITLES_BASE_URL": "https://raw.githubusercontent.com/andrey-243/office-en-subtitles/main/subtitles/"
  }
}
